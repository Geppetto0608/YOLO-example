# =========================================
# 3. 웹캠 스트리밍 UI
# =========================================
def video_stream():
    js = Javascript('''
    var video; 
    var div = null; 
    var stream; 
    var captureCanvas; 
    var imgElement; 
    var labelElement;
    var pendingResolve = null; 
    var shutdown = false;

    function removeDom() {
      if (stream) stream.getTracks().forEach(track => track.stop());
      if (video) video.remove();
      if (div) div.remove();
    }

    function onAnimationFrame() {
      if (!shutdown) window.requestAnimationFrame(onAnimationFrame);
      if (pendingResolve) {
        let result = "";
        if (!shutdown && video && video.readyState === 4) {
          captureCanvas.getContext('2d').drawImage(video, 0, 0, 640, 480);
          result = captureCanvas.toDataURL('image/jpeg', 0.8);
        }
        const p = pendingResolve;
        pendingResolve = null;
        p(result);
      }
    }

    async function createDom() {
      if (div !== null) return;

      div = document.createElement('div');
      div.style.border = '2px solid black';
      div.style.padding = '10px';
      div.style.width = '1320px';

      labelElement = document.createElement('div');
      labelElement.style.color = 'blue';
      labelElement.style.fontSize = '18px';
      labelElement.style.marginBottom = '10px';
      div.appendChild(labelElement);

      const flexDiv = document.createElement('div');
      flexDiv.style.display = 'flex';
      flexDiv.style.gap = '10px';
      div.appendChild(flexDiv);

      video = document.createElement('video');
      video.width = 640;
      video.height = 480;
      video.autoplay = true;
      flexDiv.appendChild(video);

      imgElement = document.createElement('img');
      imgElement.width = 640;
      imgElement.height = 480;
      flexDiv.appendChild(imgElement);

      const stopBtn = document.createElement('button');
      stopBtn.textContent = '중지';
      stopBtn.onclick = () => { shutdown = true; };
      div.appendChild(stopBtn);

      stream = await navigator.mediaDevices.getUserMedia({video: true});
      video.srcObject = stream;
      await video.play();

      captureCanvas = document.createElement('canvas');
      captureCanvas.width = 640;
      captureCanvas.height = 480;

      window.requestAnimationFrame(onAnimationFrame);
      document.body.appendChild(div);
    }

    async function stream_frame(label, imgData) {
      if (shutdown) {
        removeDom();
        shutdown = false;
        return "shutdown";
      }
      await createDom();
      labelElement.innerHTML = label || "";
      imgElement.src = imgData || "";
      return new Promise((resolve) => { pendingResolve = resolve; });
    }
    ''')
    display(js)

# =========================================
# 4. 프롬프트 모드 설정
#    mode 이름과 prompt 내용을 수정해도 됩니다.
# =========================================
def get_prompt(mode="caption"):
    prompts = {
        "caption": "이 장면을 한 문장으로 설명해줘.",
        "objects": "보이는 주요 물체를 5개 이하로 짧게 나열해줘.",
        "action": "사람이 있다면 무엇을 하고 있는지 짧게 설명해줘.",
        "ocr": "이미지 속 글자가 보이면 읽고 핵심만 짧게 요약해줘.",

        # ====== 추가해주세요 ======
        "custom_1": "YOUR_CUSTOM_PROMPT_1",
        "custom_2": "YOUR_CUSTOM_PROMPT_2",
        # ================================================
    }
    return prompts.get(mode, prompts["caption"])

# =========================================
# 5. VLM 분석 함수
#    model 이름을 바꿔 실험해도 됩니다.
# =========================================
def analyze_frame(img_array, mode="caption"):
    _, buffer = cv2.imencode(".jpg", img_array)
    base64_image = b64encode(buffer).decode("utf-8")
    prompt = get_prompt(mode)

    response = client.responses.create(
        model="gpt-4.1-mini",  
        input=[{
            "role": "user",
            "content": [
                {"type": "input_text", "text": prompt},
                {"type": "input_image", "image_url": f"data:image/jpeg;base64,{base64_image}"}
            ]
        }]
    )
    return response.output_text.strip()

# =========================================
# 6. 실행 파라미터 설정
# =========================================
mode = "action"           # 예: "caption", "objects", "action", "ocr", "custom_1"
analysis_interval = 4.0           # 몇 초마다 분석할지
display_prefix = "VLM 결과"       # 화면에 표시할 제목

# =========================================
# 7. 실행
# =========================================
video_stream()

label_html = "VLM 분석 대기 중..."
preview = ""
last_time = 0

try:
    while True:
        safe_label = json.dumps(label_html)
        js_reply = eval_js(f"stream_frame({safe_label}, '{preview}')")

        if js_reply == "shutdown":
            break

        img_bytes = b64decode(js_reply.split(",")[1])
        nparr = np.frombuffer(img_bytes, np.uint8)
        img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)

        current_time = time.time()
        if current_time - last_time > analysis_interval:
            try:
                result_text = analyze_frame(img, mode=mode)
                label_html = f"<b>{display_prefix}</b><br><b>mode:</b> {mode}<br><b>response:</b> {result_text}"
            except Exception as e:
                label_html = f"<b>오류</b><br>{e}"
            last_time = current_time

        _, buffer = cv2.imencode(".jpg", img)
        preview = "data:image/jpeg;base64," + b64encode(buffer).decode("utf-8")

except Exception as e:
    print("종료:", e)
