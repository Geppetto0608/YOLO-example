###KITTI Label transforms to YOLO format


import os
from PIL import Image

label_input = '/content/kitti_raw/training/label_2'
image_input = '/content/kitti_raw/training/image_2'
label_output = '/content/kitti_raw/labels_raw'

os.makedirs(label_output, exist_ok=True)

class_map = {
    'Car': 0,
    'Truck': 1,
    'Van': 2
}

for file in os.listdir(label_input):
    if not file.endswith('.txt'):
        continue

    image_path = os.path.join(image_input, file.replace('.txt', '.png'))
    label_path = os.path.join(label_input, file)
    output_path = os.path.join(label_output, file)

    if not os.path.exists(image_path):
        continue

    W, H = Image.open(image_path).size
    lines = open(label_path, 'r').readlines()
    yolo_lines = []

    for line in lines:
        parts = line.strip().split()
        cls = parts[0]

        if cls not in class_map:
            continue

        cls_id = class_map[cls]
        x1, y1, x2, y2 = map(float, parts[4:8])

        xc = ((x1 + x2) / 2) / W
        yc = ((y1 + y2) / 2) / H
        w = (x2 - x1) / W
        h = (y2 - y1) / H

        yolo_lines.append(f"{cls_id} {xc:.6f} {yc:.6f} {w:.6f} {h:.6f}\n")

    with open(output_path, 'w') as f:
        f.writelines(yolo_lines)

print("YOLO 포맷 변환 완료")




