##전체 데이터 --> 학습용(train)/검증용(val)나눔.



import os
import shutil
from sklearn.model_selection import train_test_split

image_dir = '/content/kitti_raw/training/image_2'
label_dir = '/content/kitti_raw/labels_raw'

images = sorted([f for f in os.listdir(image_dir) if f.endswith('.png')])
available_imgs = [
    f for f in images
    if os.path.exists(os.path.join(label_dir, f.replace('.png', '.txt')))
]

train_imgs, val_imgs = train_test_split(
    available_imgs, test_size=0.2, random_state=42
)

for split in ['train', 'val']:
    os.makedirs(f'/content/kitti_raw/images/{split}', exist_ok=True)
    os.makedirs(f'/content/kitti_raw/labels/{split}', exist_ok=True)

def copy_split(image_list, split):
    for img in image_list:
        img_id = os.path.splitext(img)[0]

        src_img = os.path.join(image_dir, img)
        src_lbl = os.path.join(label_dir, f'{img_id}.txt')

        dst_img = f'/content/kitti_raw/images/{split}/{img}'
        dst_lbl = f'/content/kitti_raw/labels/{split}/{img_id}.txt'

        shutil.copy(src_img, dst_img)
        shutil.copy(src_lbl, dst_lbl)

copy_split(train_imgs, 'train')
copy_split(val_imgs, 'val')

print(f'train: {len(train_imgs)}')
print(f'val: {len(val_imgs)}')
print('복사 완료')

